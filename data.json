{
  "appName": "HushNotes",
  "pages": [
    {
      "id": "page-home",
      "title": "Home",
      "icon": "home",
      "parentId": null,
      "order": 0,
      "createdAt": "2025-01-01T00:00:00Z",
      "updatedAt": "2025-04-03T00:00:00Z",
      "blocks": [
        {
          "id": "b-home-1",
          "type": "heading1",
          "content": "Welcome to HushNotes"
        },
        {
          "id": "b-home-2",
          "type": "callout",
          "content": "\ud83d\udd10 This is your private digital book. All data lives only in data.json on your machine \u2014 nothing is stored in any cloud, server, or third-party service. Load, edit, and save locally.",
          "variant": "info"
        },
        {
          "id": "b-home-3",
          "type": "heading2",
          "content": "About This Book"
        },
        {
          "id": "b-home-4",
          "type": "paragraph",
          "content": "This is a personal knowledge base built and owned entirely by Akhil Antony Joseph. It was created because every popular note-taking or wiki tool either sends your data to the cloud, requires a subscription, or locks you into a proprietary format. This book is different \u2014 it is a single JSON file that you fully control, rendered beautifully in the browser."
        },
        {
          "id": "b-home-5",
          "type": "heading2",
          "content": "Why This Exists"
        },
        {
          "id": "b-home-6",
          "type": "bulletList",
          "items": [
            {
              "id": "li-1",
              "text": "Privacy first \u2014 your notes never leave your device"
            },
            {
              "id": "li-2",
              "text": "No subscriptions, no logins, no tracking"
            },
            {
              "id": "li-3",
              "text": "Portable \u2014 one JSON file is your entire brain dump"
            },
            {
              "id": "li-4",
              "text": "Offline \u2014 works without any internet connection"
            },
            {
              "id": "li-5",
              "text": "Open \u2014 the data format is plain JSON you can read, migrate, or back up anywhere"
            }
          ]
        },
        {
          "id": "b-home-7",
          "type": "heading2",
          "content": "How to Use"
        },
        {
          "id": "b-home-8",
          "type": "numberedList",
          "items": [
            {
              "id": "nl-1",
              "text": "Use the sidebar on the left to navigate between pages"
            },
            {
              "id": "nl-2",
              "text": "Click + next to any section to create a new page or sub-page"
            },
            {
              "id": "nl-3",
              "text": "Click anywhere on a block to start editing"
            },
            {
              "id": "nl-4",
              "text": "Type / on a new line to open the block picker and insert any block type"
            },
            {
              "id": "nl-5",
              "text": "Use \u2318K (or Ctrl+K) to open global search across all your pages"
            },
            {
              "id": "nl-6",
              "text": "Hit Save in the top-right to download an updated data.json to your machine"
            },
            {
              "id": "nl-7",
              "text": "Hit Load to restore a previously saved data.json"
            }
          ]
        },
        {
          "id": "b-home-9",
          "type": "divider"
        },
        {
          "id": "b-home-10",
          "type": "paragraph",
          "content": "Start exploring the sections in the sidebar. This book is yours \u2014 make it messy, make it detailed, make it yours."
        }
      ]
    },
    {
      "id": "page-about",
      "title": "About Me",
      "icon": "person",
      "parentId": null,
      "order": 1,
      "createdAt": "2025-01-01T00:00:00Z",
      "updatedAt": "2025-04-03T00:00:00Z",
      "blocks": [
        {
          "id": "b-a1",
          "type": "heading1",
          "content": "Akhil Antony Joseph"
        },
        {
          "id": "b-a2",
          "type": "callout",
          "content": "\ud83d\udca1 This page is your personal intro \u2014 update it whenever your life changes. Think of it as your living r\u00e9sum\u00e9, only for yourself.",
          "variant": "info"
        },
        {
          "id": "b-a3",
          "type": "heading2",
          "content": "Quick Profile"
        },
        {
          "id": "b-a4",
          "type": "table",
          "content": "",
          "tableData": {
            "headers": [
              "Field",
              "Details"
            ],
            "rows": [
              [
                "Full Name",
                "Akhil Antony Joseph"
              ],
              [
                "Also Known As",
                "Akhil Antony Joseph Rio"
              ],
              [
                "Role",
                "Software Developer / Builder"
              ],
              [
                "Built This App",
                "HushNotes \u2014 personal digital book"
              ],
              [
                "Philosophy",
                "Privacy-first, locally-owned tools"
              ],
              [
                "Timezone",
                "Add your timezone here"
              ],
              [
                "Contact",
                "Add your preferred contact here"
              ]
            ]
          }
        },
        {
          "id": "b-a5",
          "type": "heading2",
          "content": "About Me"
        },
        {
          "id": "b-a6",
          "type": "paragraph",
          "content": "I am a developer who believes that the tools you use daily should serve you \u2014 not harvest you. I built HushNotes because I wanted a private, local-first knowledge base that I could trust completely. No cloud sync, no third-party servers, no vendor lock-in. Just me and my notes."
        },
        {
          "id": "b-a7",
          "type": "heading2",
          "content": "Values & Principles"
        },
        {
          "id": "b-a8",
          "type": "bulletList",
          "items": [
            {
              "id": "v1",
              "text": "Privacy is not a feature \u2014 it is a right"
            },
            {
              "id": "v2",
              "text": "Own your data, own your thinking"
            },
            {
              "id": "v3",
              "text": "Simple tools, deeply used, beat complex tools barely understood"
            },
            {
              "id": "v4",
              "text": "Write things down \u2014 memory is unreliable, JSON is not"
            },
            {
              "id": "v5",
              "text": "Build for yourself first; if others find it useful, that is a bonus"
            }
          ]
        },
        {
          "id": "b-a9",
          "type": "heading2",
          "content": "A Note to Future Me"
        },
        {
          "id": "b-a10",
          "type": "quote",
          "content": "The palest ink is better than the best memory. Write it down. Save it. Own it."
        }
      ]
    },
