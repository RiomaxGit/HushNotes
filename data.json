        {
          "id": "b-g16",
          "type": "numberedList",
          "items": [
            {
              "id": "df1",
              "text": "App loads data.json from the /public folder on startup"
            },
            {
              "id": "df2",
              "text": "All edits are held in memory (React state) \u2014 nothing is auto-saved to disk"
            },
            {
              "id": "df3",
              "text": "When you click Save, the current state is serialised to JSON and downloaded to your machine"
            },
            {
              "id": "df4",
              "text": "Replace the data.json in /public with the downloaded file to make edits permanent"
            },
            {
              "id": "df5",
              "text": "Use Load to swap in any previously saved data.json without restarting the app"
            }
